{
   "name": "shellsensors",
   "version": "0.0.4",
   "slug": "shellsensors",
   "description": "Adding different types of shell sensors to HA",
   "url": "https://github.com/demey/hassio-addons/tree/master/shellsensors",
   "startup": "application",
   "init": false,
   "uart": true,
   "udev": true,
   "usb": true,
   "arch": ["armhf", "armv7", "aarch64", "amd64", "i386"],
   "boot": "auto",
   "hassio_api": true,
   "hassio_role": "manager",
   "homeassistant_api": true,
   "map": ["share:rw"],
   "options": {
      "update_interval": 180
   },
   "schema": {
      "update_interval": "int(10,86400)"
   }
}
