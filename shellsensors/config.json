{
   "name": "shellsensors",
   "version": "0.0.1",
   "slug": "shellsensors",
   "description": "Adding different types of shell sensors to HA",
   "url": "https://github.com/demey/hassio-addons/tree/master/shellsensors",
   "startup": "application",
   "init": false,
   "uart": true,
   "udev": true,
   "usb": true,
   "arch": ["armhf", "armv7", "aarch64", "amd64", "i386"],
   "boot": "auto",
   "hassio_api": true,
   "hassio_role": "manager",
   "homeassistant_api": true,
   "map": ["share:rw"],
   "options": {
      "log_level": "debug",
      "update_interval": 30,
      "quantity": 1,
      "sensor1": {
         "name": "uvi_current",
         "type": "normal",
         "unit_of_measurement": "",
         "friendly_name": "Ультрафіолетовий індекс",
         "icon": "mdi:sun-wireless",
         "state_class": "measurement"
      }
   },
   "schema": {
      "log_level": "list(trace|debug|info|notice|warning|error|fatal)",
      "update_interval": "int(10,86400)"
   }
}
