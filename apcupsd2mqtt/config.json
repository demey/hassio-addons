{
   "name": "apcupsd2mqtt",
   "version": "1.0.2",
   "slug": "apcupsd2mqtt",
   "description":"Apcupsd to MQTT Brige",
   "url": "https://github.com/demey/hassio-addons/tree/master/apcupsd2mqtt",
   "startup": "application",
   "init":false,
   "arch":[
      "aarch64",
      "amd64",
      "armhf",
      "armv7",
      "i386"
   ],
   "boot": "auto",
   "ports": {
        "3551/tcp": 3551
    },
   "hassio_api": true,
   "hassio_role": "default",
   "options":{
      "log_level": "info",
      "update_interval": 30,
      "local_ups": false,
      "upsname": "UPS-HA",
      "onbatterydelay": 20,
      "batterylevel": 30,
      "minutes": 10,
      "mqtt":{
         "host": "127.0.0.1",
         "port": 1883,
         "username": "username",
         "password": "password",
         "topic": "homeassistant/"
      },
      "network_upses":[
         {
            "name": "apc_01",
            "url": "127.0.0.1:3551"
         },
         {
            "name": "apc_02",
            "url": "127.0.0.1:3551"
         }
      ]
   },
   "schema":{
      "device": "str?",
      "log_level": "list(trace|debug|info|notice|warning|error|fatal)",
      "update_interval": "int(1,120)",
      "local_ups": "bool",
      "upsname": "str",
      "onbatterydelay": "int",
      "batterylevel": "int",
      "minutes": "int",
      "mqtt":{
         "host": "str",
         "port": "int",
         "username": "str",
         "password": "str",
         "topic": "str"
      },
      "network_upses":[
         {
            "name": "str",
            "url": "str"
         }
      ]
   }
}