{
   "name": "Camera Videos Google Backup",
   "version": "1.0.9",
   "slug": "ha2gd",
   "description": "Sync folders with Google Drive",
   "url": "https://github.com/demey/hassio-addons/tree/master/ha2gd",
   "startup": "application",
   "init": false,
   "arch": ["armhf", "armv7", "aarch64", "amd64", "i386"],
   "boot": "auto",
   "hassio_api": true,
   "hassio_role": "default",
   "map": ["media:rw", "share:rw"],
   "options": {
      "sync_interval": 300
   },
   "schema": {
      "sync_interval": "int(10,86400)"
   }
}
